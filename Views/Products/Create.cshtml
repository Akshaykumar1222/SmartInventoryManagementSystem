@model SmartInventoryManagement.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">📦 Add New Product</h3>
        </div>

        <div class="card-body">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="ProductName" class="form-label fw-bold"></label>
                        <input asp-for="ProductName" class="form-control" placeholder="Enter Product Name" />
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Category" class="form-label fw-bold"></label>

                        <select asp-for="Category" class="form-select">
                            <option value="">-- Select Category --</option>
                            <option>Electronics</option>
                            <option>Sports</option>
                            <option>Furniture</option>
                            <option>Books</option>
                            <option>Stationery</option>
                            <option>Groceries</option>
                            <option>Other</option>
                        </select>

                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Quality" class="form-label fw-bold"></label>

                        <select asp-for="Quality" class="form-select">
                            <option value="">-- Select Quality --</option>
                            <option>Premium</option>
                            <option>Standard</option>
                            <option>Economy</option>
                        </select>

                        <span asp-validation-for="Quality" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Quantity" class="form-label fw-bold"></label>
                        <input asp-for="Quantity" class="form-control" placeholder="Enter Quantity" />
                        <span asp-validation-for="Quantity" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-bold"></label>
                        <input asp-for="Price" class="form-control" placeholder="Enter Price" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                </div>

                <div class="mt-4">

                    <button type="submit" class="btn btn-success">
                        💾 Save Product
                    </button>

                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        ← Back to Products
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}