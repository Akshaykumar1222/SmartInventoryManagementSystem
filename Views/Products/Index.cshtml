@model IEnumerable<SmartInventoryManagement.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>📦 Product Management</h2>

        <a asp-action="Create" class="btn btn-primary">
            ➕ Add Product
        </a>

    </div>

    <form asp-action="Index" method="get" class="mb-3">

        <div class="input-group">

            <input type="text"
                   name="searchString"
                   class="form-control"
                   placeholder="Search Product..." />

            <button class="btn btn-dark">
                🔍 Search
            </button>

        </div>

    </form>

    <div class="card shadow">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-dark">

                    <tr>

                        <th>Product</th>

                        <th>Category</th>

                        <th>Quality</th>

                        <th>Quantity</th>

                        <th>Status</th>

                        <th>Price</th>

                        <th>Actions</th>

                    </tr>

                </thead>

                <tbody>

                @foreach(var item in Model)
                {
                    <tr>

                        <td>
                            <strong>@item.ProductName</strong>
                        </td>

                        <td>
                            <span class="badge bg-primary">
                                @item.Category
                            </span>
                        </td>

                        <td>

                            @if(item.Quality=="Premium")
                            {
                                <span class="badge bg-success">Premium</span>
                            }
                            else if(item.Quality=="Standard")
                            {
                                <span class="badge bg-warning text-dark">Standard</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Economy</span>
                            }

                        </td>

                        <td>@item.Quantity</td>

                        <td>

                            @if(item.Quantity < 5)
                            {
                                <span class="badge bg-danger">
                                    🔴 Low Stock
                                </span>
                            }
                            else if(item.Quantity < 20)
                            {
                                <span class="badge bg-warning text-dark">
                                    🟡 Medium
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    🟢 In Stock
                                </span>
                            }

                        </td>

                        <td>

                            <strong>
                                ₹@string.Format("{0:N2}", item.Price)
                            </strong>

                        </td>

                        <td>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                ✏
                            </a>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm text-white">
                                👁
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                🗑
                            </a>

                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>

    </div>

</div>