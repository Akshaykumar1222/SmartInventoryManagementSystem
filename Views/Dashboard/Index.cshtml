@using SmartInventoryManagement.Models

@{
    ViewData["Title"] = "Dashboard";
    var recentProducts = ViewBag.RecentProducts as List<Product>;
}

<div class="container-fluid mt-4">

    <h2 class="fw-bold mb-4">📊 Smart Inventory Dashboard</h2>

    <div class="row">

        <div class="col-md-2 mb-4">
            <div class="card bg-primary text-white shadow h-100">
                <div class="card-body text-center">
                    <h6>Total Products</h6>
                    <h2>@ViewBag.TotalProducts</h2>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-4">
            <div class="card bg-success text-white shadow h-100">
                <div class="card-body text-center">
                    <h6>Total Stock</h6>
                    <h2>@ViewBag.TotalStock</h2>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-4">
            <div class="card bg-warning shadow h-100">
                <div class="card-body text-center">
                    <h6>Inventory Value</h6>
                    <h3>@ViewBag.TotalValue</h3>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-4">
            <div class="card bg-danger text-white shadow h-100">
                <div class="card-body text-center">
                    <h6>Low Stock</h6>
                    <h2>@ViewBag.LowStock</h2>
                </div>
            </div>
        </div>

        <div class="col-md-2 mb-4">
            <div class="card bg-info text-white shadow h-100">
                <div class="card-body text-center">
                    <h6>Categories</h6>
                    <h2>@ViewBag.TotalCategories</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="row">

        <div class="col-lg-8">

            <div class="card shadow">

                <div class="card-header bg-dark text-white">
                    🆕 Recent Products
                </div>

                <div class="card-body">

                    <table class="table table-hover">

                        <thead>

                        <tr>

                            <th>Product</th>

                            <th>Category</th>

                            <th>Quality</th>

                            <th>Quantity</th>

                        </tr>

                        </thead>

                        <tbody>

                        @if (recentProducts != null)
                        {
                            foreach (var item in recentProducts)
                            {
                                <tr>

                                    <td>@item.ProductName</td>

                                    <td>@item.Category</td>

                                    <td>@item.Quality</td>

                                    <td>@item.Quantity</td>

                                </tr>
                            }
                        }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="card shadow">

                <div class="card-header bg-primary text-white">
                    ⚡ Quick Actions
                </div>

                <div class="card-body d-grid gap-3">

                    <a asp-controller="Products"
                       asp-action="Create"
                       class="btn btn-success">

                        ➕ Add Product

                    </a>

                    <a asp-controller="Categories"
                       asp-action="Create"
                       class="btn btn-primary">

                        📂 Add Category

                    </a>

                    <a asp-controller="Reports"
                       asp-action="Index"
                       class="btn btn-dark">

                        📊 Reports

                    </a>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow mt-4">

        <div class="card-header bg-dark text-white">

            📈 Inventory Statistics

        </div>

        <div class="card-body">

            <canvas id="inventoryChart" height="55"></canvas>

        </div>

    </div>

</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>

        const ctx = document.getElementById('inventoryChart');

        new Chart(ctx, {

            type: 'bar',

            data: {

                labels: [
                    'Products',
                    'Categories',
                    'Low Stock'
                ],

                datasets: [{

                    label: 'Inventory',

                    data: [
                        @ViewBag.TotalProducts,
                        @ViewBag.TotalCategories,
                        @ViewBag.LowStock
                    ]

                }]

            },

            options: {

                responsive: true,

                plugins: {

                    legend: {

                        display: false

                    }

                },

                scales: {

                    y: {

                        beginAtZero: true

                    }

                }

            }

        });

    </script>
}