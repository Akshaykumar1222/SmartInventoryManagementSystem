@{
    ViewData["Title"] = "Smart Inventory Management System";
}

<div class="container mt-5">

    <div class="text-center mb-5">

        <h1 class="display-3 fw-bold text-primary">
            📦 Smart Inventory Management System
        </h1>

        <p class="lead text-secondary">
            Manage Products • Categories • Inventory • Reports
        </p>

        <a asp-controller="Dashboard"
           asp-action="Index"
           class="btn btn-primary btn-lg mt-3">
            🚀 Launch Dashboard
        </a>

    </div>

    <div class="row text-center">

        <div class="col-md-3 mb-4">

            <div class="card shadow h-100">

                <div class="card-body">

                    <h1>📦</h1>

                    <h4>Products</h4>

                    <p>
                        Add, update and manage inventory products.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-4">

            <div class="card shadow h-100">

                <div class="card-body">

                    <h1>📂</h1>

                    <h4>Categories</h4>

                    <p>
                        Organize products into categories.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-4">

            <div class="card shadow h-100">

                <div class="card-body">

                    <h1>📊</h1>

                    <h4>Reports</h4>

                    <p>
                        View inventory reports and statistics.
                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-3 mb-4">

            <div class="card shadow h-100">

                <div class="card-body">

                    <h1>📈</h1>

                    <h4>Dashboard</h4>

                    <p>
                        Monitor stock levels and inventory value.
                    </p>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow-lg mt-5">

        <div class="card-header bg-dark text-white">

            About This Project

        </div>

        <div class="card-body">

            <p>

                <strong>Smart Inventory Management System</strong> is a web application developed using
                <strong>ASP.NET Core MVC</strong>,
                <strong>Entity Framework Core</strong>,
                <strong>SQL Server</strong> and
                <strong>Bootstrap 5</strong>.

            </p>

            <ul>

                <li>✔ Product Management</li>

                <li>✔ Category Management</li>

                <li>✔ Dashboard Analytics</li>

                <li>✔ Inventory Reports</li>

                <li>✔ Search Functionality</li>

            </ul>

        </div>

    </div>

</div>